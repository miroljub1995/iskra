{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run: Iskra.Core.Client.Tests (Browser)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Iskra.BrowserTestsRunner/bin/Debug/net10.0/Iskra.BrowserTestsRunner",
            "args": [],
            "cwd": "${workspaceFolder}/src/Iskra.BrowserTestsRunner",
            "stopAtEntry": false,
            "env": {
                "RunnerBundlePath": "../../../../Iskra.Core.Client.Tests/bin/Debug/net10.0/browser-wasm/AppBundle/"
            },
            "preLaunchTask": "build: Iskra.Core.Client.Tests"
        },
        {
            "name": "Run: Iskra.WebIDLGenerator.Tests (Browser)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Iskra.BrowserTestsRunner/bin/Debug/net10.0/Iskra.BrowserTestsRunner",
            "args": [],
            "cwd": "${workspaceFolder}/src/Iskra.BrowserTestsRunner",
            "stopAtEntry": false,
            "env": {
                "RunnerBundlePath": "../../../../Iskra.WebIDLGenerator.Tests/bin/Debug/net9.0/browser-wasm/AppBundle/"
            },
            "preLaunchTask": "build: Iskra.WebIDLGenerator.Tests"
        },
        {
            "name": "Run: Iskra.TodoExample (Browser)",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "run",
                "--framework",
                "net10.0"
            ],
            "cwd": "${workspaceFolder}/examples/Iskra.TodoExample",
            "stopAtEntry": false,
            "preLaunchTask": "build: Iskra.TodoExample"
        },
        {
            "name": "Run: Iskra.CanvasExample (Browser)",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "run",
                "--framework",
                "net10.0"
            ],
            "cwd": "${workspaceFolder}/examples/Iskra.CanvasExample",
            "stopAtEntry": false,
            "preLaunchTask": "build: Iskra.CanvasExample"
        },
        {
            "name": "Run: Generate JSCore",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Iskra.WebIDLGenerator/bin/Debug/net10.0/Iskra.WebIDLGenerator",
            "args": [
                "generate",
                "${workspaceFolder}/src/Iskra.JSCore/gensettings.json"
            ],
            "cwd": "${workspaceFolder}/src/Iskra.WebIDLGenerator",
            "stopAtEntry": false,
            "preLaunchTask": "build: Iskra.WebIDLGenerator"
        },
        {
            "name": "Run: Generate Std.Web",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Iskra.WebIDLGenerator/bin/Debug/net10.0/Iskra.WebIDLGenerator",
            "args": [
                "generate",
                "${workspaceFolder}/src/Iskra.StdWeb/gensettings.json"
            ],
            "cwd": "${workspaceFolder}/src/Iskra.WebIDLGenerator",
            "stopAtEntry": false,
            "preLaunchTask": "build: Iskra.WebIDLGenerator"
        },
        {
            "name": "Run: Generate WebIDLGenerator.Tests",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Iskra.WebIDLGenerator/bin/Debug/net10.0/Iskra.WebIDLGenerator",
            "args": [
                "generate",
                "${workspaceFolder}/src/Iskra.WebIDLGenerator.Tests/gensettings.json"
            ],
            "cwd": "${workspaceFolder}/src/Iskra.WebIDLGenerator",
            "stopAtEntry": false,
            "preLaunchTask": "build: Iskra.WebIDLGenerator"
        },
        {
            "name": "Run: Iskra.Docs",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/docs/Iskra.Docs/bin/Debug/net10.0/Iskra.Docs",
            "args": [],
            "cwd": "${workspaceFolder}/docs/Iskra.Docs",
            "stopAtEntry": false,
            "preLaunchTask": "build: Iskra.Docs",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "Watch: Iskra.Docs",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "watch",
                "run",
                "--non-interactive",
                "--framework",
                "net10.0"
            ],
            "cwd": "${workspaceFolder}/docs/Iskra.Docs",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        }
    ]
}
