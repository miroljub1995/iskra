<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- NuGet Package Configuration -->
    <IsPackable>true</IsPackable>
    <PackageId>Iskra.Core</PackageId>
    <Version>$(IskraCoreVersion)</Version>
    <Authors>miroljub1995</Authors>
    <Description>Core framework for building reactive WebAssembly UIs with C# and .NET — component model, rendering, signals, and source generators.</Description>
    <PackageTags>webassembly;wasm;dotnet;components;reactive;ui;blazor</PackageTags>
    <PackageProjectUrl>https://github.com/miroljub1995/iskra</PackageProjectUrl>
    <RepositoryUrl>https://github.com/miroljub1995/iskra</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Iskra.Signals\Iskra.Signals.csproj" />
    <!-- Generator: no output reference needed at compile time; bundled into NuGet for consumers -->
    <ProjectReference Include="..\Iskra.Core.Generators\Iskra.Core.Generators.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
  <!-- Bundle generator DLL into the NuGet package so consumers get it automatically -->
  <ItemGroup>
    <None Include="..\Iskra.Core.Generators\bin\$(Configuration)\netstandard2.0\Iskra.Core.Generators.dll"
          Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>
  <!-- Bundle static asset targets for NuGet consumers -->
  <ItemGroup>
    <None Include="targets\Iskra.Core.StaticAssets.targets" Pack="true" PackagePath="build/Iskra.Core.targets" Visible="false" />
    <None Include="targets\Iskra.Core.StaticAssets.targets" Pack="true" PackagePath="buildTransitive/Iskra.Core.targets" Visible="false" />
  </ItemGroup>
</Project>
